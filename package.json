{
  "name": "notepad-app",
  "version": "1.2.2",
  "description": "Ứng dụng Notepad / Ghi chú - Dự án Công Nghệ Phần Mềm (Electron + Electron Builder)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.example.notepadapp",
    "productName": "Notepad App",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "icon": "assets/icon.png",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "SaintLaurentxTran",
        "repo": "notepad-app",
	"releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "NotepadApp-Setup-${version}.${ext}"
    }
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}